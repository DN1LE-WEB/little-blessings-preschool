---
import { site, nav } from '../data/site';
import Icon from './Icon.astro';
const year = 2026;
---
<footer class="site-footer section--green">
  <div class="container footer-grid">
    <div class="footer-brand">
      <div class="brand">
        <span class="brand-mark" aria-hidden="true"><Icon name="cross" /></span>
        <span class="brand-text">
          <strong>Little Blessings</strong>
          <em>Preschool</em>
        </span>
      </div>
      <p class="footer-tag">
        A Christ-centered preschool nurturing young hearts and minds in Madison, Minnesota —
        a ministry of {site.ministryOf}.
      </p>
      <div class="footer-social">
        <a href={site.social.facebook} aria-label="Facebook" target="_blank" rel="noopener">
          <Icon name="facebook" />
        </a>
        <a href={site.social.church} aria-label="Faith Lutheran Church website" target="_blank" rel="noopener">
          <Icon name="church" />
        </a>
      </div>
    </div>

    <div class="footer-col">
      <h4>Explore</h4>
      <ul>
        {nav.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
        <li><a href={site.social.facebook} target="_blank" rel="noopener">Facebook ↗</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Visit Us</h4>
      <ul class="footer-contact">
        <li>
          <Icon name="pin" class="ic-gold" />
          <span>{site.address.name}<br />{site.address.street}<br />{site.address.city}, {site.address.state} {site.address.zip}</span>
        </li>
        <li><Icon name="phone" class="ic-gold" /><a href={site.phoneHref}>{site.phone}</a></li>
        <li><Icon name="check" class="ic-gold" /><span>{site.license}</span></li>
      </ul>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>© {year} {site.name}. All are welcome here.</p>
    <p class="footer-credit">“Train up a child in the way he should go.” — Proverbs 22:6</p>
  </div>
</footer>

<style>
  .site-footer { color: var(--sage-200); }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1.3fr;
    gap: 2.5rem;
    padding-bottom: 3rem;
  }
  .brand { display: flex; align-items: center; gap: 0.7rem; }
  .brand-mark {
    display: grid; place-items: center;
    width: 46px; height: 46px; border-radius: 14px;
    background: rgba(255, 255, 255, 0.14);
    color: #fff;
  }
  .brand-mark :global(svg) { width: 24px; height: 24px; }
  .brand-text { display: flex; flex-direction: column; line-height: 1.05; font-family: var(--font-display); }
  .brand-text strong { font-size: 1.28rem; color: #fff; }
  .brand-text em {
    font-style: normal; font-size: 0.72rem; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase; color: var(--gold-400);
  }
  .footer-tag { margin-top: 1.1rem; max-width: 42ch; color: var(--sage-200); font-size: 0.97rem; }

  .footer-social { display: flex; gap: 0.7rem; margin-top: 1.2rem; }
  .footer-social a {
    width: 44px; height: 44px; border-radius: 14px;
    display: grid; place-items: center;
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    transition: background 0.2s var(--ease), transform 0.2s var(--ease), color 0.2s var(--ease);
  }
  .footer-social a:hover { background: var(--gold-500); color: var(--green-900); transform: translateY(-2px); }
  .footer-social :global(svg) { width: 20px; height: 20px; }

  .footer-col h4 {
    color: #fff; font-family: var(--font-display); font-weight: 700;
    font-size: 0.95rem; letter-spacing: 0.06em; text-transform: uppercase;
    margin-bottom: 1.1rem;
  }
  .footer-col ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.6rem; }
  .footer-col a { color: var(--sage-200); }
  .footer-col a:hover { color: #fff; }

  .footer-contact li { display: flex; gap: 0.65rem; align-items: flex-start; }
  .footer-contact :global(svg) { width: 19px; height: 19px; flex: none; margin-top: 4px; }

  .footer-bottom {
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem;
    padding-top: 1.8rem; border-top: 1px solid rgba(255, 255, 255, 0.16);
    font-size: 0.9rem; color: var(--sage-200);
  }
  .footer-bottom p { margin: 0; }
  .footer-credit { color: var(--gold-400); font-family: var(--font-display); }

  @media (max-width: 820px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
    .footer-brand { grid-column: 1 / -1; }
  }
  @media (max-width: 520px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>
