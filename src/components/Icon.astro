---
// Lightweight inline SVG icon set. `name` selects the glyph.
interface Props {
  name: string;
  class?: string;
}
const { name, class: className } = Astro.props;

const paths: Record<string, string> = {
  cross:
    '<path d="M10 3h4v5h5v4h-5v9h-4v-9H5V8h5V3Z"/>',
  church:
    '<path d="M12 2l3 2.5V7M12 2 9 4.5V7m3-2.5V8M5 21V11l7-4 7 4v10M5 21h14M9 21v-4a3 3 0 0 1 6 0v4"/>',
  heart:
    '<path d="M12 20s-7-4.4-7-9.3A3.7 3.7 0 0 1 12 7a3.7 3.7 0 0 1 7 3.7C19 15.6 12 20 12 20Z"/>',
  sun:
    '<path d="M12 6.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM12 2v2m0 16v2M4 12H2m20 0h-2M5 5l1.5 1.5M17.5 17.5 19 19M19 5l-1.5 1.5M6.5 17.5 5 19"/>',
  book:
    '<path d="M12 6c-1.6-1.2-4-2-6.5-2H4v14h1.5c2.5 0 4.9.8 6.5 2m0-14c1.6-1.2 4-2 6.5-2H20v14h-1.5c-2.5 0-4.9.8-6.5 2m0-14v14"/>',
  blocks:
    '<path d="M4 8h6V4H4v4Zm0 12h6v-6H4v6Zm10 0h6v-9h-6v9Zm0-12 2-3 2 3-2 3-2-3Z"/>',
  palette:
    '<path d="M12 3a9 9 0 0 0 0 18c1.4 0 2-1 2-2 0-1.3-1-1.6-1-2.7 0-.8.7-1.3 1.5-1.3H17a4 4 0 0 0 4-4c0-4.4-4-8-9-8Zm-4 9a1 1 0 1 1 0-2 1 1 0 0 1 0 2Zm2-4a1 1 0 1 1 0-2 1 1 0 0 1 0 2Zm5 0a1 1 0 1 1 0-2 1 1 0 0 1 0 2Z"/>',
  apple:
    '<path d="M12 8c-1.5-1.5-5-2-6.5.5S6 18 9 19.5c1.5.8 1.5-.5 3-.5s1.5 1.3 3 .5c3-1.5 5-8.5 3.5-11S13.5 6.5 12 8Zm0 0V5a3 3 0 0 1 3-3"/>',
  leaf:
    '<path d="M5 19C4 14 6 5 19 5c0 13-9 15-14 14Zm0 0C7 14 11 10 16 8"/>',
  music:
    '<path d="M9 18V5l11-2v13M9 18a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm11-2a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>',
  users:
    '<path d="M16 18v-1a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v1m6.5-9a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM21 18v-1a4 4 0 0 0-3-3.8M16 5.2A3 3 0 0 1 16 11"/>',
  star:
    '<path d="m12 3 2.6 5.3 5.9.9-4.3 4.1 1 5.8L12 16.9 6.8 19.6l1-5.8L3.5 9.7l5.9-.9L12 3Z"/>',
  smile:
    '<path d="M12 3a9 9 0 1 0 0 18 9 9 0 0 0 0-18ZM9 10h.01M15 10h.01M8.5 14a4 4 0 0 0 7 0"/>',
  phone:
    '<path d="M6 3h3l2 5-2.5 1.5a11 11 0 0 0 5 5L16 14l5 2v3a2 2 0 0 1-2 2A16 16 0 0 1 4 5a2 2 0 0 1 2-2Z"/>',
  pin:
    '<path d="M12 21s-6-5.3-6-10a6 6 0 1 1 12 0c0 4.7-6 10-6 10Zm0-7.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z"/>',
  mail:
    '<path d="M4 5h16a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Zm0 2 8 6 8-6"/>',
  clock:
    '<path d="M12 3a9 9 0 1 0 0 18 9 9 0 0 0 0-18Zm0 4v5l4 2"/>',
  arrow:
    '<path d="M5 12h14m-6-7 7 7-7 7"/>',
  check:
    '<path d="m5 12 4.5 4.5L19 7"/>',
  facebook:
    '<path d="M14 8.5V7c0-.8.5-1 1-1h2V3h-3c-2.2 0-3 1.5-3 3.5v2H9v3h2v9h3v-9h2.2l.8-3H14Z"/>',
};

const d = paths[name] ?? paths.star;
---
<svg
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.7"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={d}
/>

<style>
  /* Sensible default size so icons never balloon in flex contexts.
     More specific parent rules override this. */
  svg {
    width: 1.25em;
    height: 1.25em;
    flex: none;
  }
</style>
