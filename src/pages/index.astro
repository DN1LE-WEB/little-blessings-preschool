---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { site, reasons, day, steps } from '../data/site';

import firstDay from '../assets/photos/first-day-group.jpg';
import singing from '../assets/photos/singing-sanctuary.jpg';
import teacher from '../assets/photos/teacher-activity.jpg';
import readingNook from '../assets/photos/reading-nook.jpg';
import listening from '../assets/photos/listening-center.jpg';
import lightTable from '../assets/photos/light-table.jpg';
import writingDesk from '../assets/photos/writing-desk.jpg';
import beanbag from '../assets/photos/beanbag-corner.jpg';
import ourBlessings from '../assets/photos/our-little-blessings.jpg';

const mapSrc = `https://maps.google.com/maps?q=${site.mapQuery}&t=&z=15&ie=UTF8&iwloc=&output=embed`;

const peek = [
  { img: readingNook, caption: 'Our cozy reading nook' },
  { img: lightTable, caption: 'Light-table discovery' },
  { img: teacher, caption: 'Hands-on science with Miss Teacher' },
  { img: listening, caption: 'The listening center' },
  { img: beanbag, caption: 'A comfy corner to land' },
  { img: writingDesk, caption: 'Little writing desks' },
];
---
<BaseLayout>
  <!-- Hero ------------------------------------------------------------ -->
  <section class="hero">
    <span class="blob blob--sky" aria-hidden="true"></span>
    <span class="blob blob--gold" aria-hidden="true"></span>
    <div class="container hero-inner">
      <div class="hero-copy">
        <span class="pill pill--gold">Now enrolling · Just 10 Pre-K spots</span>
        <h1>
          Where little ones grow in
          <span class="ink-sky">faith</span>,
          <span class="ink-coral">friendship</span> &amp;
          <span class="ink-gold">wonder</span>.
        </h1>
        <p class="lead">
          Little Blessings is a Christ-centered Pre-K in Madison, Minnesota. With just
          10 spots, every child is loved by name and gets ready for kindergarten through play.
        </p>
        <div class="cluster mt-3">
          <a href="#visit" class="btn btn--primary">Schedule a Visit <Icon name="arrow" /></a>
          <a href={site.phoneHref} class="btn btn--ghost"><Icon name="phone" /> {site.phone}</a>
        </div>
        <p class="hero-trust">
          A ministry of <strong>{site.ministryOf}</strong> · children of all faiths
          &amp; backgrounds welcome
        </p>
      </div>

      <div class="hero-media">
        <div class="frame frame--hero">
          <Image src={firstDay} alt="Little Blessings preschoolers lined up smiling on their first day of school outside the church entrance" widths={[480, 760, 1040]} sizes="(max-width: 960px) 92vw, 540px" loading="eager" />
        </div>
        <span class="photo-tag">🎒 First day of school!</span>
      </div>
    </div>
    <div class="wave" aria-hidden="true">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none"><path d="M0,40 C240,90 480,0 720,30 C960,60 1200,90 1440,40 L1440,80 L0,80 Z"/></svg>
    </div>
  </section>

  <!-- Welcome --------------------------------------------------------- -->
  <section class="section" id="welcome">
    <div class="container welcome-grid">
      <div class="welcome-copy">
        <span class="eyebrow eyebrow--green">Welcome, families</span>
        <h2>A gentle place to begin.</h2>
        <p class="lead">
          Every child is a gift. Our Pre-K is a safe, joyful place with Christ at the
          center, where your child can play, make friends, and love learning.
        </p>
        <p>
          Because we keep just 10 spots, our teacher knows each child by name. Days are
          full of stories, songs, art, outdoor play, and prayer, building the curiosity
          and confidence kids carry into kindergarten.
        </p>
        <blockquote class="verse">
          {site.verse.text}
          <cite>{site.verse.ref}</cite>
        </blockquote>
        <a href="#day" class="btn btn--ghost">See a day with us <Icon name="arrow" /></a>
      </div>

      <div class="welcome-media">
        <div class="frame frame--tall">
          <Image src={teacher} alt="A teacher leads a hands-on glow-in-the-dark science activity with a circle of preschoolers" widths={[420, 680]} sizes="(max-width: 900px) 90vw, 440px" loading="lazy" />
        </div>
        <div class="frame frame--inset">
          <Image src={readingNook} alt="A cozy classroom reading nook with beanbags, soft pillows, and a picture-book display" widths={[300, 460]} sizes="(max-width: 900px) 50vw, 240px" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Celebrating our Little Blessings -------------------------------- -->
  <section class="section celebrate">
    <span class="blob blob--coral" aria-hidden="true"></span>
    <div class="container celebrate-grid">
      <div class="celebrate-media">
        <div class="frame frame--photo">
          <Image src={ourBlessings} alt="The Little Blessings Preschool class smiling together on the playground in their bright green Little Blessings shirts" widths={[440, 720]} sizes="(max-width: 900px) 90vw, 460px" loading="lazy" />
        </div>
        <span class="photo-tag">💛 Our Little Blessings</span>
      </div>

      <div class="celebrate-copy">
        <span class="eyebrow eyebrow--gold">Fearfully &amp; wonderfully made</span>
        <h2>Celebrating our Little Blessings.</h2>
        <p class="lead">
          This week we're celebrating our Little Blessings and all of God's children.
          Every one of them is a gift, made with purpose and loved beyond measure.
        </p>
        <blockquote class="verse verse--gold">
          “For you created my inmost being; you knit me together in my mother's womb.
          I praise you because I am fearfully and wonderfully made; your works are
          wonderful, I know that full well.”
          <cite>Psalm 139:13–14</cite>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- A day with us --------------------------------------------------- -->
  <section class="section section--alt" id="day">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow eyebrow--sky">A day with us</span>
        <h2>Joyful from hello to goodbye.</h2>
        <p class="lead">Predictable, gentle rhythms help little ones feel safe and free to explore.</p>
      </div>
      <ol class="timeline">
        {day.map((d) => (
          <li class="tl">
            <span class="tl-dot" aria-hidden="true"></span>
            <span class="tl-time">{d.time}</span>
            <div class="tl-body">
              <h3>{d.title}</h3>
              <p>{d.text}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Faith band (full-bleed photo) ----------------------------------- -->
  <section class="faith">
    <Image class="faith-bg" src={singing} alt="Preschoolers singing together at the front of the church sanctuary beneath the stained-glass windows" widths={[760, 1200, 1800]} sizes="100vw" loading="lazy" />
    <div class="faith-scrim" aria-hidden="true"></div>
    <div class="container faith-inner">
      <span class="faith-label">Christ at the center</span>
      <blockquote>
        “Train up a child in the way he should go; even when he is old he will not depart from it.”
      </blockquote>
      <cite>Proverbs 22:6</cite>
      <p>
        Faith isn't a single lesson on our calendar. It's the love, patience, and grace
        woven through every part of our day, from morning prayer to the songs we sing.
      </p>
    </div>
  </section>

  <!-- Why families choose us ------------------------------------------ -->
  <section class="section" id="why">
    <div class="container">
      <div class="section-head section-head--center">
        <span class="eyebrow eyebrow--green">Why families choose us</span>
        <h2>More than a preschool. A family.</h2>
      </div>
      <div class="reasons">
        {reasons.map((r, i) => (
          <div class="reason">
            <span class={`reason-rule rule--${['sky','gold','coral','green','sky','gold'][i % 6]}`} aria-hidden="true"></span>
            <h3>{r.title}</h3>
            <p>{r.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Peek inside our room -------------------------------------------- -->
  <section class="section section--alt" id="peek">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow eyebrow--gold">Come on in</span>
        <h2>A peek inside our room.</h2>
        <p class="lead">Bright corners for reading, building, creating, and resting, all
          made just their size.</p>
      </div>
      <div class="peek-grid">
        {peek.map((item) => (
          <figure class="peek-item">
            <Image src={item.img} alt={item.caption} widths={[320, 520]} sizes="(max-width: 700px) 90vw, (max-width: 1000px) 45vw, 360px" loading="lazy" />
            <figcaption>{item.caption}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- Visit / Enroll -------------------------------------------------- -->
  <section class="section section--soft" id="visit">
    <div class="container visit-grid">
      <div class="visit-info">
        <span class="eyebrow eyebrow--coral">Visit &amp; enroll</span>
        <h2>We'd love to meet you.</h2>
        <p class="lead">
          The best way to know if we're right for your family is to come see us. Enrolling
          is simple, and with only 10 spots, it's worth reaching out early. Here's how to begin.
        </p>

        <ol class="steps">
          {steps.map((s) => (
            <li class="step">
              <span class="step-n">{s.n}</span>
              <div>
                <h3>{s.title}</h3>
                <p>{s.text}</p>
              </div>
            </li>
          ))}
        </ol>

        <div class="contact-box">
          <a href={site.phoneHref} class="contact-row">
            <span class="contact-ic"><Icon name="phone" /></span>
            <span><strong>Call us</strong><br />{site.phone}</span>
          </a>
          <a href={site.social.facebook} class="contact-row" target="_blank" rel="noopener">
            <span class="contact-ic"><Icon name="facebook" /></span>
            <span><strong>Message us</strong><br />on Facebook</span>
          </a>
          <div class="contact-row">
            <span class="contact-ic"><Icon name="pin" /></span>
            <span><strong>{site.address.name}</strong><br />{site.address.street}, {site.address.city}, {site.address.state} {site.address.zip}</span>
          </div>
        </div>

        <div class="cluster mt-3">
          <a href={site.phoneHref} class="btn btn--primary"><Icon name="phone" /> Call to Enroll</a>
          <a href={site.social.facebook} class="btn btn--ghost" target="_blank" rel="noopener"><Icon name="facebook" /> Find Us on Facebook</a>
        </div>
      </div>

      <div class="visit-map">
        <iframe
          title={`Map to ${site.name}`}
          src={mapSrc}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
        <div class="hours-panel">
          <h3><Icon name="clock" class="ic-gold" /> Class times</h3>
          <ul>
            {site.hours.map((h) => (
              <li><span>{h.day}</span><span>{h.time}</span></li>
            ))}
          </ul>
          <p class="hours-note">{site.license} · Call to check spot availability.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- shared photo frames ---- */
  .frame { border-radius: var(--radius-lg); overflow: hidden; background: var(--white); box-shadow: var(--shadow-md); }
  .frame :global(img) { width: 100%; height: 100%; object-fit: cover; display: block; }

  .ink-sky { color: var(--sky-600); }
  .ink-coral { color: var(--coral-500); }
  .ink-gold { color: var(--gold-600); }
  .ink-green { color: var(--green-600); }

  .pill--gold { background: var(--gold-100); color: var(--gold-600); }

  /* ---- Hero ---- */
  .hero { position: relative; overflow: hidden; padding-block: clamp(2rem, 5vw, 4rem) clamp(5rem, 9vw, 8rem); }
  .blob { position: absolute; border-radius: 50%; filter: blur(10px); z-index: 0; opacity: 0.5; }
  .blob--sky { width: 44vw; max-width: 540px; aspect-ratio: 1; top: -18%; right: -8%;
    background: radial-gradient(circle, var(--sky-200), transparent 66%); }
  .blob--gold { width: 38vw; max-width: 460px; aspect-ratio: 1; bottom: -22%; left: -12%;
    background: radial-gradient(circle, rgba(246, 183, 60, 0.4), transparent 66%); }
  .hero-inner { position: relative; z-index: 1; display: grid; grid-template-columns: 1.02fr 0.98fr; gap: 3.5rem; align-items: center; }
  .hero-copy h1 { margin-top: 1rem; }
  .hero-trust { display: block; margin-top: 1.9rem; color: var(--muted); font-size: 0.96rem; font-weight: 600; }
  .hero-trust strong { color: var(--green-700); }

  .hero-media { position: relative; }
  .frame--hero { aspect-ratio: 4 / 3; transform: rotate(1.4deg); border: 6px solid var(--white); }
  .photo-tag {
    position: absolute; left: -0.4rem; bottom: -1.1rem;
    background: var(--white); color: var(--green-800);
    font-family: var(--font-display); font-weight: 700; font-size: 1rem;
    padding: 0.6rem 1.1rem; border-radius: 999px; box-shadow: var(--shadow-md);
    transform: rotate(-2.5deg);
  }

  .wave { position: absolute; bottom: -1px; left: 0; right: 0; line-height: 0; z-index: 1; }
  .wave svg { width: 100%; height: 58px; display: block; }
  .wave svg path { fill: var(--cream); }

  /* ---- Welcome ---- */
  .welcome-grid { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 3.5rem; align-items: center; }
  .verse {
    margin: 1.75rem 0; padding: 1.3rem 1.5rem;
    background: var(--sky-100); border-left: 5px solid var(--sky-500);
    border-radius: 0 var(--radius) var(--radius) 0;
    font-family: var(--font-display); font-weight: 600; font-size: 1.15rem;
    color: var(--sky-700); line-height: 1.5;
  }
  .verse cite { display: block; margin-top: 0.55rem; font-style: normal; font-size: 0.92rem; color: var(--sky-600); }

  .welcome-media { position: relative; padding-bottom: 2.5rem; padding-left: 2.5rem; }
  .frame--tall { aspect-ratio: 4 / 5; }
  .frame--inset {
    position: absolute; left: 0; bottom: 0; width: 47%; aspect-ratio: 1 / 1;
    border: 5px solid var(--white);
  }

  /* ---- Programs (editorial list, no cards) ---- */
  .programs { display: grid; gap: 0; }
  .prog {
    display: grid; grid-template-columns: 210px 1fr; gap: 2.5rem; align-items: center;
    padding: 2.1rem 0; border-top: 1px solid var(--line);
  }
  .prog:last-child { border-bottom: 1px solid var(--line); }
  .prog-age {
    position: relative; border-radius: var(--radius); padding: 1.5rem 1.25rem;
    text-align: center; display: flex; flex-direction: column; gap: 0.15rem;
  }
  .prog--sky .prog-age { background: var(--sky-100); }
  .prog--gold .prog-age { background: var(--gold-100); }
  .prog--coral .prog-age { background: var(--coral-100); }
  .prog-ages { font-family: var(--font-display); font-weight: 700; font-size: 2.1rem; line-height: 1; color: var(--heading); }
  .prog--sky .prog-ages { color: var(--sky-700); }
  .prog--gold .prog-ages { color: var(--gold-600); }
  .prog--coral .prog-ages { color: var(--coral-600); }
  .prog-label {
    font-family: var(--font-display); font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.08em; font-size: 0.78rem; color: var(--ink-soft);
  }
  .prog-flag {
    margin-top: 0.6rem; align-self: center; font-family: var(--font-display); font-weight: 700;
    font-size: 0.72rem; letter-spacing: 0.04em; text-transform: uppercase;
    background: var(--coral-500); color: #fff; padding: 0.22rem 0.7rem; border-radius: 999px;
  }
  .prog-body h3 { font-size: clamp(1.45rem, 2.6vw, 1.85rem); margin-bottom: 0.4rem; }
  .prog-body > p { color: var(--text-soft); margin-bottom: 0.7rem; }
  .prog-tags { display: flex; flex-wrap: wrap; align-items: center; gap: 0.55rem; margin: 0;
    font-family: var(--font-display); font-weight: 600; font-size: 0.95rem; color: var(--green-700); }
  .prog-tags .tag-item { display: inline-flex; align-items: center; gap: 0.55rem; }
  .prog-tags .dot { color: var(--muted); }

  /* ---- Celebrating our Little Blessings ---- */
  .celebrate { position: relative; overflow: hidden; background: var(--gold-100); }
  .blob--coral { width: 40vw; max-width: 480px; aspect-ratio: 1; top: -24%; right: -10%;
    background: radial-gradient(circle, var(--coral-100), transparent 66%); }
  .celebrate-grid {
    position: relative; z-index: 1; display: grid; grid-template-columns: 0.9fr 1.1fr;
    gap: 3.5rem; align-items: center;
  }
  .celebrate-media { position: relative; }
  .frame--photo { aspect-ratio: 4 / 5; transform: rotate(-1.4deg); border: 6px solid var(--white); }
  .verse--gold {
    background: var(--white); border-left-color: var(--gold-500); color: var(--green-800);
  }
  .verse--gold cite { color: var(--gold-600); }

  /* ---- Timeline (de-iconed) ---- */
  .timeline { list-style: none; margin: 0; padding: 0; position: relative; display: grid; gap: 0.2rem; max-width: 760px; }
  .timeline::before { content: ''; position: absolute; left: 7px; top: 14px; bottom: 14px; width: 2px; background: var(--line); }
  .tl { position: relative; display: grid; grid-template-columns: 130px 1fr; gap: 1.5rem; align-items: baseline; padding: 0.85rem 0 0.85rem 2rem; }
  .tl-dot {
    position: absolute; left: 0; top: 1.45rem; width: 16px; height: 16px; border-radius: 50%;
    background: var(--white); border: 3px solid var(--sky-500);
  }
  .tl:nth-child(3n+2) .tl-dot { border-color: var(--gold-500); }
  .tl:nth-child(3n+3) .tl-dot { border-color: var(--coral-500); }
  .tl-time {
    font-family: var(--font-display); font-weight: 700; font-size: 0.82rem;
    letter-spacing: 0.06em; text-transform: uppercase; color: var(--sky-700);
  }
  .tl-body h3 { margin: 0 0 0.2rem; font-size: 1.2rem; }
  .tl-body p { margin: 0; color: var(--text-soft); }

  /* ---- Faith band (full-bleed) ---- */
  .faith { position: relative; overflow: hidden; padding-block: clamp(4.5rem, 10vw, 8rem); color: #fff; }
  .faith-bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; }
  .faith-scrim { position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(180deg, rgba(20, 52, 40, 0.78), rgba(20, 52, 40, 0.62)); }
  .faith-inner { position: relative; z-index: 2; max-width: 820px; margin-inline: auto; text-align: center; }
  .faith-label {
    display: inline-block; font-family: var(--font-display); font-weight: 700;
    font-size: 0.9rem; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--gold-400); margin-bottom: 1rem;
  }
  .faith blockquote {
    font-family: var(--font-display); font-weight: 700; font-size: clamp(1.6rem, 3.6vw, 2.4rem);
    line-height: 1.32; color: #fff; margin: 0 0 0.7rem;
  }
  .faith cite { display: block; font-style: normal; font-weight: 600; color: var(--gold-400); margin-bottom: 1.4rem; }
  .faith-inner > p { color: rgba(255,255,255,0.9); font-size: 1.1rem; max-width: 60ch; margin-inline: auto; }

  /* ---- Why (feature list, no icons/cards) ---- */
  .reasons { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2.5rem 3rem; }
  .reason-rule { display: block; width: 38px; height: 4px; border-radius: 4px; margin-bottom: 1rem; }
  .rule--sky { background: var(--sky-500); }
  .rule--gold { background: var(--gold-500); }
  .rule--coral { background: var(--coral-500); }
  .rule--green { background: var(--green-500); }
  .reason h3 { font-size: 1.25rem; margin-bottom: 0.4rem; }
  .reason p { margin: 0; color: var(--text-soft); font-size: 0.99rem; }

  /* ---- Peek inside (authentic gallery) ---- */
  .peek-grid { columns: 3; column-gap: 1.25rem; }
  .peek-item { margin: 0 0 1.25rem; break-inside: avoid; }
  .peek-item :global(img) {
    width: 100%; height: auto; display: block; border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
  }
  .peek-item figcaption {
    margin-top: 0.55rem; font-family: var(--font-display); font-weight: 600;
    font-size: 0.88rem; color: var(--ink-soft);
  }

  /* ---- Visit / Enroll ---- */
  .section--soft { background: var(--sky-100); }
  .visit-grid { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 3.5rem; align-items: start; }
  .steps { list-style: none; margin: 1.75rem 0; padding: 0; display: grid; gap: 1.2rem; }
  .step { display: grid; grid-template-columns: 48px 1fr; gap: 1rem; align-items: start; }
  .step-n {
    width: 48px; height: 48px; display: grid; place-items: center;
    border-radius: 50%; background: var(--green-600); color: #fff;
    font-family: var(--font-display); font-weight: 700; font-size: 1.25rem;
  }
  .step:nth-child(2) .step-n { background: var(--sky-600); }
  .step:nth-child(3) .step-n { background: var(--gold-500); color: var(--green-900); }
  .step:nth-child(4) .step-n { background: var(--coral-500); }
  .step h3 { margin: 0.1rem 0 0.2rem; font-size: 1.2rem; }
  .step p { margin: 0; color: var(--text-soft); font-size: 0.98rem; }

  .contact-box {
    display: grid; gap: 0.25rem; margin-top: 2rem; padding: 1rem 1.25rem;
    background: var(--white); border-radius: var(--radius); box-shadow: var(--shadow-sm);
  }
  .contact-row { display: flex; align-items: center; gap: 0.9rem; padding: 0.7rem 0.25rem; color: var(--ink); }
  .contact-row + .contact-row { border-top: 1px solid var(--line); }
  a.contact-row:hover { color: var(--green-700); }
  .contact-ic {
    flex: none; width: 44px; height: 44px; display: grid; place-items: center;
    border-radius: 14px; background: var(--sky-100); color: var(--sky-700);
  }
  .contact-ic :global(svg) { width: 22px; height: 22px; }
  .contact-row span strong { font-family: var(--font-display); }

  .visit-map { position: sticky; top: 96px; display: grid; gap: 1.25rem; }
  .visit-map iframe {
    width: 100%; height: 300px; border: 0; border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }
  .hours-panel { background: var(--white); border-radius: var(--radius); padding: 1.5rem 1.6rem; box-shadow: var(--shadow-sm); }
  .hours-panel h3 { display: flex; align-items: center; gap: 0.5rem; font-size: 1.2rem; margin-bottom: 0.9rem; }
  .hours-panel h3 :global(svg) { width: 22px; height: 22px; }
  .hours-panel ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.55rem; }
  .hours-panel li { display: flex; justify-content: space-between; gap: 1rem; font-size: 0.95rem; }
  .hours-panel li span:first-child { font-weight: 700; color: var(--green-800); }
  .hours-panel li span:last-child { color: var(--text-soft); text-align: right; }
  .hours-note { margin: 1rem 0 0; font-size: 0.85rem; color: var(--muted); }

  /* ---- Responsive ---- */
  @media (max-width: 960px) {
    .hero-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .hero-media { order: -1; max-width: 520px; }
    .welcome-grid, .visit-grid { grid-template-columns: 1fr; }
